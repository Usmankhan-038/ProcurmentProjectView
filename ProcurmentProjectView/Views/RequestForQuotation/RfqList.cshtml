@{
    ViewData["Title"] = "RFQ List";
}

<div class="container-fluid ps-4 pt-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">Request for Quotations</h1>
            <p class="text-muted mb-0">Browse and manage your RFQs.</p>
        </div>
        <div>
            <a asp-controller="RequestForQuotation" asp-action="Create" class="btn text-white" style="background-color: #0F52BA; border-radius: 10px; padding: 10px 20px;">
                <i class="bi bi-plus-lg me-1"></i> Add RFQ
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>PR Number</th>
                        <th>RFQ Number</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Static Data representing RFQs -->
                    <tr>
                        <td><span class="fw-bold">PR-1001</span></td>
                        <td>RFQ-5001</td>
                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                        <td class="text-end">
                            <a class="btn btn-link text-danger p-0 me-2" asp-controller="RequestForQuotation" asp-action="Delete" asp-route-id="1" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a class="btn btn-link text-primary p-0 me-2" asp-controller="RequestForQuotation" asp-action="RfqDetail" asp-route-id="1" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a class="btn btn-link text-success p-0" asp-controller="RequestForQuotation" asp-action="Edit" asp-route-id="1" title="Edit">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="fw-bold">PR-1002</span></td>
                        <td>RFQ-5002</td>
                        <td><span class="badge bg-success">Approved</span></td>
                        <td class="text-end">
                            <a class="btn btn-link text-danger p-0 me-2" asp-controller="RequestForQuotation" asp-action="Delete" asp-route-id="2" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a class="btn btn-link text-primary p-0 me-2" asp-controller="RequestForQuotation" asp-action="RfqDetail" asp-route-id="2" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a class="btn btn-link text-success p-0" asp-controller="RequestForQuotation" asp-action="Edit" asp-route-id="2" title="Edit">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

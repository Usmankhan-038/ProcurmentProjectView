<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProcurmentProjectView</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProcurmentProjectView.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="container-fluid p-0 app-shell">
        <div class="d-flex app-shell__body">

            <nav id="sidebar" class="app-sidebar shadow-sm">
                <div class="app-sidebar__brand border-bottom">
                    <strong class="d-block">Procurment App</strong>
                    <small class="text-muted">Operations</small>
                </div>

                <ul class="nav flex-column app-sidebar__nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex justify-content-between align-items-center"
                           data-bs-toggle="collapse" href="#productsMenu" role="button" aria-expanded="false" aria-controls="productsMenu">
                            <span><i class="bi bi-box-seam"></i> Products</span>
                            <i class="bi bi-chevron-down small"></i>
                        </a>
                        <div class="collapse" id="productsMenu">
                            <ul class="nav flex-column app-sidebar__subnav">
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="AddProduct">
                                        Add Product
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="ProductList">
                                        Product List
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-clipboard-check"></i>
                            <span>Purchase Requisition</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Main Content: Takes up ALL remaining space -->
            <div id="content" class="flex-grow-1 bg-light px-4 py-4 app-content">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ProcurmentProjectView - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

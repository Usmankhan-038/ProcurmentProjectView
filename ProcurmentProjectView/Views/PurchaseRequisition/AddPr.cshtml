@model ProductModel
@{
    ViewData["Title"] = "Add Product";
}

<div class="container-fluid ps-4 pt-4">
    <div class="mb-4">
        <h1 class="display-6 fw-bold mb-1">Add Product</h1>
        <p class="text-muted mb-0">Create a new product record.</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="SaveProduct" asp-controller="Product" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Product Name</label>
                        <input type="text" asp-for="Name" class="form-control" placeholder="Enter product name" />
                    </div>
               
                    <div class="col-md-6">
                        <label class="form-label">Company</label>
                        <input type="text" asp-for="Company" class="form-control" placeholder="Merik" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Description</label>
                        <input type="text" asp-for="Description" class="form-control" placeholder="10 PC" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">UPC</label>
                        <input type="text" asp-for="Upc" class="form-control" placeholder="UPC" />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Product</button>
                    <button type="reset" class="btn btn-outline-secondary ms-2">Clear</button>
                </div>
            </form>
        </div>
    </div>
</div>

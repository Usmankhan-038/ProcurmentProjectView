@model ProcurmentProjectView.Models.PrDetailResponseModel


@if (Model == null)
{
    <div class="container mt-5">
        <div class="alert alert-danger text-center">
            <h4>Error: Purchase Requisition Not Found</h4>
            <p>The requested Pr data Could not be loaded or does not exist</p>
            <a asp-controller ="PurchaseRequisition" asp-action="PrList" class="btn btn-primary">Back To List</a>
        </div>

    </div>
   
    return;
    
}
@{
    ViewData["Title"] = "PR Details";
}

<div class="container-fluid ps-4 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">Purchase Requisition Details</h1>
            <p class="text-muted mb-0">View PR and associated products.</p>
        </div>
        <div>
            <a asp-controller="PurchaseRequisition" asp-action="PrList" class="btn btn-outline-secondary me-2">
                Back to List
            </a>
            <a asp-controller="PurchaseRequisition" asp-action="Edit" asp-route-id='@ViewContext.RouteData.Values["id"]' class="btn text-white" style="background-color: #0F52BA;">
                Edit PR
            </a>
        </div>
    </div>

    <!-- PR Details - Full Width Card -->
    <div class="card border-0 shadow-sm mb-4 w-100">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h5 class="fw-bold text-primary mb-0"><i class="bi bi-file-earmark-text me-2"></i>PR Summary</h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-3">
                    <p class="text-muted mb-1 small text-uppercase fw-bold">Title</p>
                    <p class="mb-0 fs-5">@Model.Title</p>
                </div>
                <div class="col-md-3">
                    <p class="text-muted mb-1 small text-uppercase fw-bold">Estimated Budget</p>
                    <p class="mb-0 fs-5">@Model.EstimationBudget</p>
                </div>
                <div class="col-md-3">
                    <p class="text-muted mb-1 small text-uppercase fw-bold">Quantity</p>
                    <p class="mb-0 fs-5">@Model.Quantity</p>
                </div>
                <div class="col-md-3">
                    <p class="text-muted mb-1 small text-uppercase fw-bold">Delivery Date</p>
                    <p class="mb-0 fs-5">@Model.DeliveryDate</p>
                </div>
                @* <div class="col-12">
                    <p class="text-muted mb-1 small text-uppercase fw-bold">Note</p>
                    <div class="p-3 bg-light rounded border-start border-4 border-primary">
                        <p class="mb-0">@Model.Note</p>
                    </div>
                </div> *@
            </div>
        </div>
    </div>

    <!-- Products List -->
    <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
        <h4 class="fw-bold mb-0">Products</h4>
        <a asp-controller="Product" asp-action="AddProduct" class="btn btn-sm btn-outline-success">
            <i class="bi bi-plus-lg"></i> Add Product
        </a>
    </div>

    <div class="row g-3">
        @if (Model.Products != null && Model.Products.Any())
        {
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 product-card position-relative">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-dark mb-0">@product.GetName()</h5>
                                <div class="action-buttons">
                                    <a asp-controller="Product" asp-action="ViewProduct" asp-route-id="@product.Id" class="btn btn-sm btn-link text-primary p-0 me-2" title="View">
                                        <i class="bi bi-eye fs-5"></i>
                                    </a>
                                    <a asp-controller="Product" asp-action="UpdateProduct" asp-route-id="@product.Id" class="btn btn-sm btn-link text-success p-0 me-2" title="Edit">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </a>
                                    <a asp-controller="Product" asp-action="DeleteProduct" asp-route-id="@product.Id" class="btn btn-sm btn-link text-danger p-0" title="Delete">
                                        <i class="bi bi-trash fs-5"></i>
                                    </a>
                                </div>
                            </div>
                            <h6 class="card-subtitle mb-3 text-muted">@product.GetCompany()</h6>
                            
                            <div class="mb-2">
                                <span class="badge bg-secondary me-1">UPC:</span>
                                <span class="text-dark fw-medium">@product.GetUpc()</span>
                            </div>
                            <p class="card-text text-muted small mt-3">@product.GetDescription()</p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-light border text-center py-4 text-muted" role="alert">
                    <i class="bi bi-box-seam d-block mb-2 fs-3"></i>
                    No products associated with this PR.
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .product-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>
@{
    ViewData["Title"] = "View Product";
}

@model ProcurmentProjectView.Models.ProductModel

<div class="container-fluid ps-4 pt-4">
    <!-- Use Flexbox to align header and button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">View Product</h1>
            <p class="text-muted mb-0">Product details overview.</p>
        </div>
        <div>
            <a asp-controller="Product" asp-action="AddProduct" class="btn text-white" style="background-color: #0F52BA; border-radius: 10px; padding: 10px 20px;">
                Add Product
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="max-width: 100%;">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 fw-bold text-secondary">Product Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4 fw-bold text-secondary">Company</dt>
                <dd class="col-sm-8">@Model.Company</dd>

                <dt class="col-sm-4 fw-bold text-secondary">UPC</dt>
                <dd class="col-sm-8">@Model.Upc</dd>

                <dt class="col-sm-4 fw-bold text-secondary">Created Date</dt>
                <dd class="col-sm-8">@Model.createdAt</dd>

                <dt class="col-sm-4 fw-bold text-secondary">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>
            </dl>
        </div>
    </div>
</div>
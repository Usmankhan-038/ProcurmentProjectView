@{
    ViewData["Title"] = "Products";
}

<div class="container-fluid ps-4 pt-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">Products</h1>
            <p class="text-muted mb-0">Manage product details and inventory.</p>
        </div>
        <div class="input-group" style="max-width: 320px;">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Search products" />
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Add Product</div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label">Product Name</label>
                            <input type="text" class="form-control" placeholder="Enter product name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <input type="text" class="form-control" placeholder="Enter category" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Unit Price</label>
                            <input type="number" class="form-control" placeholder="0.00" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quantity</label>
                            <input type="number" class="form-control" placeholder="0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" placeholder="Add description"></textarea>
                        </div>
                        <button type="button" class="btn btn-primary w-100">Save Product</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Product List</div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Printer Ink</td>
                                <td>Office Supplies</td>
                                <td>$45.00</td>
                                <td>120</td>
                                <td class="text-end">
                                    <button class="btn btn-link text-primary p-0 me-2" type="button"><i class="bi bi-eye"></i></button>
                                    <button class="btn btn-link text-success p-0 me-2" type="button"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn btn-link text-danger p-0" type="button"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Laptop Stand</td>
                                <td>Accessories</td>
                                <td>$28.50</td>
                                <td>48</td>
                                <td class="text-end">
                                    <button class="btn btn-link text-primary p-0 me-2" type="button"><i class="bi bi-eye"></i></button>
                                    <button class="btn btn-link text-success p-0 me-2" type="button"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn btn-link text-danger p-0" type="button"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Packaging Boxes</td>
                                <td>Logistics</td>
                                <td>$12.00</td>
                                <td>300</td>
                                <td class="text-end">
                                    <button class="btn btn-link text-primary p-0 me-2" type="button"><i class="bi bi-eye"></i></button>
                                    <button class="btn btn-link text-success p-0 me-2" type="button"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn btn-link text-danger p-0" type="button"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

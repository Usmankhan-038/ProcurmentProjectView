@{
    ViewData["Title"] = "View Product";
}

<div class="container-fluid ps-4 pt-4">
    <div class="mb-4">
        <h1 class="display-6 fw-bold mb-1">View Product</h1>
        <p class="text-muted mb-0">Product details overview.</p>
    </div>

    <div class="card border-0 shadow-sm" style="max-width: 720px;">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Product Name</dt>
                <dd class="col-sm-8">Printer Ink</dd>
                <dt class="col-sm-4 text-muted">Category</dt>
                <dd class="col-sm-8">Office Supplies</dd>
                <dt class="col-sm-4 text-muted">SKU</dt>
                <dd class="col-sm-8">SKU-001</dd>
                <dt class="col-sm-4 text-muted">Unit Price</dt>
                <dd class="col-sm-8">$45.00</dd>
                <dt class="col-sm-4 text-muted">Quantity</dt>
                <dd class="col-sm-8">120</dd>
                <dt class="col-sm-4 text-muted">Supplier</dt>
                <dd class="col-sm-8">Acme Supplies</dd>
                <dt class="col-sm-4 text-muted">Description</dt>
                <dd class="col-sm-8">Premium printer ink for office use.</dd>
            </dl>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid ps-4 pt-4">
    <!-- Added padding for that left margin you wanted -->
    <h1 class="display-5 fw-bold">Welcome To Procurement Project</h1>
    <p class="text-muted">We deal with all types of supply and delivery</p>

    <div class="row mt-4">
        <!-- Card 1 -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm bg-light text-dark">
                <div class="card-header border-0 bg-transparent opacity-75">Total PR</div>
                <div class="card-body">
                    <h2 class="card-title fw-bold">12</h2>
                </div>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm bg-light text-dark">
                <div class="card-header border-0 bg-transparent opacity-75">Pending PR</div>
                <div class="card-body">
                    <h2 class="card-title fw-bold">5</h2>
                </div>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm bg-light text-dark">
                <div class="card-header border-0 bg-transparent opacity-75">Approved PR</div>
                <div class="card-body">
                    <h2 class="card-title fw-bold">7</h2>
                </div>
            </div>
        </div>
    </div>
</div>
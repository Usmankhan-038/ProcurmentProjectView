@model ProcurmentProjectView.DTOs.PrDataDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid ps-4 pt-4">
    <!-- Added padding for that left margin you wanted -->
    <h1 class="display-5 fw-bold">Welcome To Procurement Project</h1>
    <p class="text-muted">We deal with all types of supply and delivery</p>

    <div class="row mt-4">
        <!-- Card 1 -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm bg-light text-dark">
                <div class="card-header border-0 bg-transparent opacity-75">Total PR</div>
                <div class="card-body">
                    <h2 class="card-title fw-bold">@(Model != null ? Model.TotalPrCount : 0)</h2>
                </div>
            </div>
        </div>

        <!-- Loop through status counts to create cards dynamically -->
        @if (Model != null && Model.PrStatusCount != null)
        {
            foreach (var status in Model.PrStatusCount)
            {
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm bg-light text-dark">
                        <div class="card-header border-0 bg-transparent opacity-75 text-capitalize">@status.RfqStatus PR</div>
                        <div class="card-body">
                            <h2 class="card-title fw-bold">@status.TotalCount</h2>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Fallback if no status counts available -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm bg-light text-dark">
                    <div class="card-header border-0 bg-transparent opacity-75">Pending PR</div>
                    <div class="card-body">
                        <h2 class="card-title fw-bold">0</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm bg-light text-dark">
                    <div class="card-header border-0 bg-transparent opacity-75">Approved PR</div>
                    <div class="card-body">
                        <h2 class="card-title fw-bold">0</h2>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@{
    ViewData["Title"] = "Update Product";
}

<div class="container-fluid ps-4 pt-4">
    <div class="mb-4">
        <h1 class="display-6 fw-bold mb-1">Update Product</h1>
        <p class="text-muted mb-0">Edit product information.</p>
    </div>

    <div class="card border-0 shadow-sm" style="max-width: 720px;">
        <div class="card-body">
            <form>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Product Name</label>
                        <input type="text" class="form-control" value="Printer Ink" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <input type="text" class="form-control" value="Office Supplies" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">SKU</label>
                        <input type="text" class="form-control" value="SKU-001" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Unit Price</label>
                        <input type="number" class="form-control" value="45" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" value="120" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Supplier</label>
                        <input type="text" class="form-control" value="Acme Supplies" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3">Premium printer ink for office use.</textarea>
                    </div>
                </div>
                <div class="mt-4">
                    <button type="button" class="btn btn-primary">Update Product</button>
                    <button type="button" class="btn btn-outline-secondary ms-2">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
